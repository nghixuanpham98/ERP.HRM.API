{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ERP_HRM_DB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "your-very-strong-secret-key-here-must-be-32-chars-or-longer",
    "Issuer": "ERP.HRM.API",
    "Audience": "ERP.HRM.Client",
    "ExpireMinutes": "60",
    "RefreshTokenExpirationDays": "7"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200",
      "http://localhost:5173"
    ]
  },
  "RateLimiting": {
    "MaxRequests": 100,
    "TimeWindowSeconds": 60
  },
  "ApplicationSettings": {
    "MaxPageSize": 100,
    "DefaultPageSize": 10
  }
}

